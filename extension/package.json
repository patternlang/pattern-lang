{
  "name": "pattern-language-support",
  "displayName": "Pattern Language Support",
  "description": "Language support for Pattern language with LSP integration",
  "version": "0.0.1",
  "publisher": "pattern-lang",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/pattern-lang"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:pattern"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "pattern",
        "extensions": [".pattern"],
        "aliases": ["Pattern", "pattern"]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run copy-lsp",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "copy-lsp": "node scripts/copy-lsp.js",
    "build": "npm run compile && npm run copy-lsp",
    "package": "npm run build && vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
